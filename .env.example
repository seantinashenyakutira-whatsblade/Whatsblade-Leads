# ═══════════════════════════════════════════════════════════
# Whatsblade Leads — Enterprise Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════

# ─── SUPABASE ─────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── APP ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=Whatsblade Leads
NEXT_PUBLIC_APP_ENV=development

# ─── ENCRYPTION ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for API key vault encryption (AES-256-GCM)
ENCRYPTION_KEY=your-32-byte-hex-key-here-must-be-exactly-64-hex-chars

# ─── GOOGLE ───────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Maps JavaScript API, Geocoding API
# Also create OAuth 2.0 credentials for Google Sheets/Calendar
GOOGLE_PLACES_API_KEY=AIzaSy...
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── FACEBOOK / META ──────────────────────────────────────
# Get from: Meta for Developers → Your App → Settings
# https://developers.facebook.com/apps/
# Requires: Pages Read Engagement, Instagram Basic Display permissions
FACEBOOK_ACCESS_TOKEN=EAAB...
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── AI / GEMINI ──────────────────────────────────────────
# Get from: Google AI Studio → Get API Key
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ─── REDIS (Upstash — for caching & rate limiting) ────────
# Get from: Upstash Console → Create Redis Database
# https://console.upstash.com/
# Used for: Google Places cache (24hr TTL), rate limit counters, session store
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── WEB PUSH NOTIFICATIONS (VAPID) ───────────────────────
# Generate with: npx web-push generate-vapid-keys
# Used for: lead replies, meeting reminders, daily summary push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@domain.com

# ─── ANALYTICS (PostHog) ──────────────────────────────────
# Get from: PostHog → Project Settings
# https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── SECURITY ─────────────────────────────────────────────
# Session timeout in seconds (default: 1800 = 30 minutes)
SESSION_MAX_AGE=1800
# Rate limiting: max requests per window
RATE_LIMIT_MAX_REQUESTS=100
# Rate limiting window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# CORS: comma-separated allowed origins (no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://w-leads.vercel.app
# Content Security Policy (customize as needed)
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' https://*.supabase.co https://*.googleapis.com https://*.gstatic.com data: blob:; connect-src 'self' https://*.supabase.co https://*.posthog.com https://*.googleapis.com; font-src 'self' data:;

# ─── VERCEL ───────────────────────────────────────────────
# Set automatically on Vercel deployment, override if needed
VERCEL_URL=w-leads.vercel.app
